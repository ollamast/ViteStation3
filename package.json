{
    "name": "vitestation3",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "homepage": ".",
    "scripts": {
        "dev": "vite",
        "type-check": "vue-tsc --noEmit",
        "build": "vite build",
        "preview": "vite preview",
        "test:unit": "vitest",
        "lint": "eslint . --fix",
        "format": "prettier --write src/",
        "deploy": "vite build && cp dist/index.html dist/404.html && gh-pages -d dist -b prod",
        "force-deploy": "cp dist/index.html dist/404.html && gh-pages -d dist -b prod"
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1",
        "pinia": "^3.0.4",
        "vue": "^3.3.4",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "gh-pages": "^6.3.0",
        "@types/node": "^25.6.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.1",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.0.3",
        "sass": "^1.69.5",
        "typescript": "^6.0.3",
        "vite": "^8.0.8",
        "vitest": "^4.1.4",
        "vue-tsc": "^3.2.6"
    }
}
